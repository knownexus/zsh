# ---------------------------------------------------------------------------
# Archive — create a zip of the current HEAD
# ---------------------------------------------------------------------------
gar() {
    local repo_name="${1:-$(basename "$(git rev-parse --show-toplevel)")}"
    repo_name="${repo_name// /_}"
    local hash out
    hash=$(git rev-parse --short HEAD)
    out="${repo_name}-${hash}.zip"
    git archive --format=zip HEAD -o "$out"
    echo "Created $out ($(du -sh "$out" | cut -f1))"
}

