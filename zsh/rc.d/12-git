# ---------------------------------------------------------------------------
# Log — rich format (mirrors pwsh gl / gl2)
# ---------------------------------------------------------------------------
_gl_log_header() {
    local esc=$'\033'
    local reset="${esc}[0m" gray="${esc}[90m" cyan="${esc}[36m"
    local green="${esc}[32m" red="${esc}[31m"
    local up='↑' dn='↓'

    local status_lines branch upstream ab
    status_lines=$(git status --porcelain=v2 --branch 2>/dev/null)
    branch=$(echo "$status_lines"   | grep '^# branch.head '     | sed 's/^# branch.head //')
    upstream=$(echo "$status_lines" | grep '^# branch.upstream ' | sed 's/^# branch.upstream //')
    ab=$(echo "$status_lines"       | grep '^# branch.ab '       | sed 's/^# branch.ab //')

    if [[ -n "$upstream" ]]; then
        local origin_short ahead="" behind=""
        origin_short=$(git rev-parse --short=7 '@{upstream}' 2>/dev/null)
        ahead=$(echo "$ab"  | grep -oP '(?<=\+)\d+' || true)
        behind=$(echo "$ab" | grep -oP '(?<=-)\d+' || true)
        local ahead_str="" behind_str=""
        [[ -n "$ahead"  && "$ahead"  -gt 0 ]] && ahead_str="  ${cyan}${up}${ahead} ahead${reset}"
        [[ -n "$behind" && "$behind" -gt 0 ]] && behind_str="  ${red}${dn}${behind} behind${reset}"
        echo "${gray}origin:${reset} ${cyan}${origin_short}${reset} ${gray}(${upstream})${reset}${ahead_str}${behind_str}"
    fi

    local head_full
    head_full=$(git rev-parse HEAD 2>/dev/null)
    for candidate in develop master main origin/develop origin/master origin/main; do
        [[ "$candidate" == "$branch" || "$candidate" == "origin/$branch" ]] && continue
        local merge_sha
        merge_sha=$(git merge-base HEAD "$candidate" 2>/dev/null) || continue
        [[ "$merge_sha" == "$head_full" ]] && continue
        local base_short commit_count
        base_short=$(git rev-parse --short=7 "$merge_sha")
        commit_count=$(git rev-list --count "${merge_sha}..HEAD" 2>/dev/null)
        echo "${gray}base:${reset}   ${green}${base_short}${reset} ${gray}(${candidate})${reset}  ${gray}${commit_count} commit(s) on this branch${reset}"
        break
    done

    echo ""
}

gl() {
    _gl_log_header
    git log --color=always \
        '--format=tformat:%C(yellow)%H%C(reset)%C(auto)%d%C(reset)%n%C(brightblack)%an <%ae>  %ad%C(reset)%n%n%C(249)%w(0,4,4)%B%C(reset)' \
        '--date=format:%a %d/%m/%y %H:%M' \
        "$@" | less -R
}
alias gitl='gl'

gl2() {
    local esc=$'\033'
    local reset="${esc}[0m" gray="${esc}[90m" green="${esc}[32m" red="${esc}[31m"
    _gl_log_header
    local pending_sha="" buffer=()
    while IFS= read -r line; do
        # Detect a commit SHA line (may be preceded by ANSI escapes)
        if echo "$line" | grep -qP '(?:\x1b\[\d+m)*[0-9a-f]{40}'; then
            if [[ -n "$pending_sha" ]]; then
                echo "$pending_sha"
                printf '%s\n' "${buffer[@]}"
                buffer=()
            fi
            pending_sha="$line"
        elif [[ "$line" == ">>END<<" ]]; then
            : # consumed
        elif echo "$line" | grep -qP '^\s*\d+ files? changed'; then
            local f i d
            f=$(echo "$line" | grep -oP '^\s*\K\d+(?= file)')
            i=$(echo "$line" | grep -oP '\d+(?= insertion)' || echo "0")
            d=$(echo "$line" | grep -oP '\d+(?= deletion)'  || echo "0")
            echo "${pending_sha}  ${gray}${f}f ${green}+${i}${reset} ${red}-${d}${reset}"
            pending_sha=""
            printf '%s\n' "${buffer[@]}"
            buffer=()
        else
            if [[ -n "$pending_sha" ]]; then
                buffer+=("$line")
            else
                echo "$line"
            fi
        fi
    done < <(git log --color=always --shortstat \
        '--format=tformat:%C(yellow)%H%C(reset)%C(auto)%d%C(reset)%n%C(brightblack)%an <%ae>  %ad%C(reset)%n%n%C(249)%w(0,4,4)%B%w(0,0,0)%C(reset)%n>>END<<' \
        '--date=format:%a %d/%m/%y %H:%M' \
        "$@")
}
alias gitl2='gl2'

