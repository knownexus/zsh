# Hard-reset to remote HEAD using fetch + FETCH_HEAD (works without tracking ref)
gitremote-reset() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)
    git fetch origin "$branch"
    git reset --hard FETCH_HEAD
}
