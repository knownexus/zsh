# Rebase onto origin of current branch using fetch+FETCH_HEAD
gro() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)
    git fetch origin "$branch"
    git rebase FETCH_HEAD "$@"
}

groi() {
    local branch
    branch=$(git rev-parse --abbrev-ref HEAD)
    git fetch origin "$branch"
    git rebase -i FETCH_HEAD "$@"
}

grod() {
    git fetch origin develop
    git rebase FETCH_HEAD "$@"
}

# Fetch a named remote branch then rebase onto it
grof() {
    local remote="${1#origin/}"   # strip leading 'origin/' if present
    git fetch origin "$remote"
    git rebase FETCH_HEAD
}

# Interactive rebase — integer N rebases HEAD~N; SHA/branch rebases from that ref's parent
gri() {
    local target="${1:-1}"
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        git rebase -i "HEAD~${target}"
    else
        git rebase -i "${target}^"
    fi
}

grim() {
    local target="${1:-1}"
    if [[ "$target" =~ ^[0-9]+$ ]]; then
        git rebase -i --rebase-merges "HEAD~${target}"
    else
        git rebase -i --rebase-merges "${target}^"
    fi
}

# Rebase onto a branch found by partial name in the reflog
rebaseon() {
    local fragment="$1"
    local branch
    branch=$(git reflog show --all 2>/dev/null \
        | grep "$fragment" \
        | grep 'refs/' \
        | awk 'NR==1{print $2}' \
        | sed -e 's|refs/remotes/||' -e 's/@{.*//')
    if [[ -n "$branch" ]]; then
        git rebase "$branch"
    else
        echo "No branch matching '$fragment' found in reflog" >&2
        return 1
    fi
}
alias rebase='rebaseon'

