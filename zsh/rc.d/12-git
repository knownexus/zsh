# -*- sh -*-
# Git aliases — mirrors pwsh 12-git

# ---------------------------------------------------------------------------
# _help_print — render a man-page-style help string with ANSI colour
# ---------------------------------------------------------------------------
_help_print() {
    local esc=$'\033'
    local bold="${esc}[1m" yellow="${esc}[33m" cyan="${esc}[36m" reset="${esc}[0m"
    while IFS= read -r line; do
        if [[ "$line" =~ ^(NAME|SYNOPSIS|DESCRIPTION|OPTIONS|EXAMPLES|SEE\ ALSO)$ ]]; then
            echo "${bold}${yellow}${line}${reset}"
        elif [[ "$line" =~ ^'    '-  ]]; then
            echo "${bold}${cyan}${line}${reset}"
        else
            echo "$line"
        fi
    done
}

# ---------------------------------------------------------------------------
# Status
# ---------------------------------------------------------------------------
gstat() {
    local esc=$'\033'
    local reset="${esc}[0m"  bold="${esc}[1m"
    local green="${esc}[32m" red="${esc}[31m" yellow="${esc}[33m"
    local cyan="${esc}[36m"  gray="${esc}[90m"
    local up='↑' dn='↓'

    local branch revno
    branch=$(git symbolic-ref --short HEAD 2>/dev/null) || branch=$(git rev-parse --short HEAD 2>/dev/null)
    revno=$(git rev-parse --short=7 HEAD 2>/dev/null)

    local ahead behind ahead_str="" behind_str=""
    ahead=$(git rev-list --count '@{upstream}..HEAD' 2>/dev/null || true)
    behind=$(git rev-list --count 'HEAD..@{upstream}' 2>/dev/null || true)
    [[ -n "$ahead"  && "$ahead"  -gt 0 ]] && ahead_str=" ${green}${up}${ahead}${reset}"
    [[ -n "$behind" && "$behind" -gt 0 ]] && behind_str=" ${red}${dn}${behind}${reset}"

    echo "${bold}branch:${reset} ${cyan}${branch}${reset} ${gray}${revno}${reset}${ahead_str}${behind_str}"
    echo ""

    local lines staged unstaged conflicts untracked
    lines=$(git status --porcelain 2>/dev/null)
    staged=$(echo "$lines"    | grep -E '^[AMDRC]'                 || true)
    unstaged=$(echo "$lines"  | grep -E '^.[MD]'                   || true)
    conflicts=$(echo "$lines" | grep -E '^(UU|AA|DD|AU|UA|DU|UD)' || true)
    untracked=$(echo "$lines" | grep -E '^\?\?'                    || true)

    if [[ -n "$staged" ]]; then
        echo "${bold}${green}Staged:${reset}"
        while IFS= read -r l; do
            local label
            case "${l:0:1}" in
                A) label="new file" ;; M) label="modified" ;;
                D) label="deleted " ;; R) label="renamed " ;;
                C) label="copied  " ;; *) label="${l:0:1}"  ;;
            esac
            echo "  ${green}${label}:${reset} ${l:3}"
        done <<< "$staged"
        echo ""
    fi

    if [[ -n "$unstaged" ]]; then
        echo "${bold}${red}Unstaged:${reset}"
        while IFS= read -r l; do
            local label
            case "${l:1:1}" in
                M) label="modified" ;; D) label="deleted " ;; *) label="${l:1:1}" ;;
            esac
            echo "  ${red}${label}:${reset} ${l:3}"
        done <<< "$unstaged"
        echo ""
    fi

    if [[ -n "$conflicts" ]]; then
        echo "${bold}${yellow}Conflicts:${reset}"
        while IFS= read -r l; do
            echo "  ${yellow}conflict:${reset} ${l:3}"
        done <<< "$conflicts"
        echo ""
    fi

    if [[ -n "$untracked" ]]; then
        echo "${bold}${gray}Untracked:${reset}"
        while IFS= read -r l; do
            echo "  ${gray}${l:3}${reset}"
        done <<< "$untracked"
        echo ""
    fi

    [[ -z "$lines" ]] && echo "${green}Nothing to commit, working tree clean${reset}"
}
alias g!='gstat'
alias git!='gstat'

