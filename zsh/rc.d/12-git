# ---------------------------------------------------------------------------
# Worktree helpers
# ---------------------------------------------------------------------------

# Returns the project root (bare or standard layout)
_wt_project_root() {
    local main
    main=$(git worktree list --porcelain | grep '^worktree ' | head -1 | sed 's/^worktree //')
    if [[ -d "$main/.git" ]]; then
        echo "$main"
    else
        dirname "$main"
    fi
}

# Returns all worktree paths
_wt_paths() {
    git worktree list --porcelain | grep '^worktree ' | sed 's/^worktree //'
}

# Navigate to a worktree by partial path name
wt-go() {
    local name="$1"
    local match
    match=$(_wt_paths | grep "$name" | head -1)
    if [[ -n "$match" ]]; then
        cd "$match"
    else
        echo "No worktree matching '$name'" >&2
        return 1
    fi
}

# List all worktrees
wt-list() { git worktree list; }

# Create a feature/ worktree + branch
wt-feature() {
    local ticket="$1" desc="$2" base="${3:-develop}"
    local root wtpath
    root=$(_wt_project_root)
    wtpath="$root/feature/$ticket-$desc"
    git worktree add "$wtpath" -b "feature/$ticket-$desc" "$base"
}

# Create a fix/ worktree + branch
wt-fix() {
    local ticket="$1" desc="$2" base="${3:-develop}"
    local root wtpath
    root=$(_wt_project_root)
    wtpath="$root/fix/$ticket-$desc"
    git worktree add "$wtpath" -b "fix/$ticket-$desc" "$base"
}

# Check out an existing branch into a new worktree, preserving path structure
# e.g. wt-c feature/ABC-123-foo  →  <root>/feature/ABC-123-foo
wt-c() {
    local branch="$1"
    local root wtpath
    root=$(_wt_project_root)
    wtpath="$root/$branch"
    git worktree add "$wtpath" "$branch"
}

# Remove a worktree and safe-delete its local branch
wt-done() {
    local name="$1"
    local match branch
    match=$(_wt_paths | grep "$name" | head -1)
    if [[ -z "$match" ]]; then echo "No worktree matching '$name'" >&2; return 1; fi
    branch=$(git -C "$match" branch --show-current)
    git worktree remove "$match"
    [[ -n "$branch" ]] && git branch -d "$branch"
}

# Force-remove a worktree + hard-delete its branch (unmerged ok)
wt-done-f() {
    local name="$1"
    local match branch
    match=$(_wt_paths | grep "$name" | head -1)
    if [[ -z "$match" ]]; then echo "No worktree matching '$name'" >&2; return 1; fi
    branch=$(git -C "$match" branch --show-current)
    git worktree remove --force "$match"
    [[ -n "$branch" ]] && git branch -D "$branch"
}

# Show git status for every worktree
_wt_status() {
    _wt_paths | while IFS= read -r wt; do
        echo ""
        echo "=== $wt ==="
        git -C "$wt" status --short
    done
}
alias 'wt!'='_wt_status'

# Prune stale worktree references
wt-prune() { git worktree prune -v; }

# Set up a multi-worktree workspace
# Usage: wt-setup <branch,...> [repo-name] [clone-url] [parent-path]
wt-setup() {
    local branches_str="" name="" clone_url="" path="$(pwd)"

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -b|-branches|--branches) shift; branches_str="$1" ;;
            -n|-name|--name)         shift; name="$1" ;;
            -u|-url|--url)           shift; clone_url="$1" ;;
            -p|-path|--path)         shift; path="$1" ;;
            *) echo "Unknown argument: $1" >&2; return 1 ;;
        esac
        shift
    done

    if [[ -z "$branches_str" ]]; then
        echo "Usage: wt-setup -b <branch[,branch,...]> [-n name] [-u clone-url] [-p path]" >&2
        return 1
    fi

    local -a branches
    IFS=',' read -ra branches <<< "$branches_str"

    local git_root workspace_dir
    if [[ -n "$clone_url" ]]; then
        local repo_name="${clone_url##*/}"; repo_name="${repo_name%.git}"
        [[ -z "$name" ]] && name="$repo_name"
        local clone_target="$path/$name/.git-main"
        echo "Cloning $clone_url → $clone_target"
        git clone --bare "$clone_url" "$clone_target"
        git -C "$clone_target" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
        git -C "$clone_target" fetch --all --quiet
        git_root="$clone_target"
        workspace_dir="$path/$name"
    else
        git_root=$(git rev-parse --show-toplevel 2>/dev/null)
        if [[ -z "$git_root" ]]; then
            echo "Not inside a git repo. Use --url to clone one." >&2; return 1
        fi
        [[ -z "$name" ]] && name="$(basename "$git_root")"
        workspace_dir="$(dirname "$git_root")/$name"
        mkdir -p "$workspace_dir"
    fi

    echo "Workspace: $workspace_dir"
    for branch in "${branches[@]}"; do
        local safe_name="${branch//\//-}"
        local wtpath="$workspace_dir/$safe_name"
        if git -C "$git_root" rev-parse --verify "$branch" &>/dev/null; then
            echo "  [$branch] existing local"
            git -C "$git_root" worktree add "$wtpath" "$branch"
        elif git -C "$git_root" rev-parse --verify "origin/$branch" &>/dev/null; then
            echo "  [$branch] tracking remote"
            git -C "$git_root" worktree add --track -b "$branch" "$wtpath" "origin/$branch"
        else
            echo "  [$branch] new branch"
            git -C "$git_root" worktree add -b "$branch" "$wtpath"
        fi
    done
}

# ---------------------------------------------------------------------------
# fix-fetch-refspecs — add missing fetch refspecs to all local repos
# ---------------------------------------------------------------------------
fix-fetch-refspecs() {
    local root="${1:-$HOME/repos}"
    for dir in "$root"/*/; do
        [[ -d "$dir/.git" ]] || continue
        local fetch
        fetch=$(git -C "$dir" config --get-all remote.origin.fetch 2>/dev/null || true)
        if [[ -z "$fetch" ]]; then
            echo "Fixing: $(basename "$dir")"
            git -C "$dir" config remote.origin.fetch '+refs/heads/*:refs/remotes/origin/*'
            git -C "$dir" remote update
        fi
    done
}
