# Editor
# ------------------------------
alias c='claude'

# ------------------------------
# Filesystem helpers
# ------------------------------
# open — launch a file/URL with the default app (Linux)
alias open='xdg-open'

# path — show PATH entries one per line
path() { echo "$PATH" | tr ':' '\n'; }

# psgrep — find a running process by partial name
psgrep() { ps aux | grep -i "$1" | grep -v grep; }

# brk — horizontal rule across the terminal
brk() {
    local width="${COLUMNS:-80}"
    printf '%*s\n' "$width" '' | tr ' ' '─'
}

# remspace — strip trailing whitespace from all files in current dir
# (existing alias handles single file; this handles dir-wide)
remspace_dir() { find . -maxdepth 1 -type f | xargs sed -i 's/[[:space:]]*$//' ; }
